---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 | 김민준 Portfolio"
  description="요청한 경로를 찾을 수 없습니다. 김민준 포트폴리오 홈으로 돌아갈 수 있습니다."
  canonical="https://minjoon.me/404/"
>
  <main id="main" class="portfolio-not-found portfolio-reading">
    <section class="not-found-panel" aria-labelledby="not-found-title">
      <p class="code-comment">// HTTP 404</p>
      <h1 id="not-found-title">페이지를 찾을 수 없습니다.</h1>
      <p>요청한 경로가 없거나 포트폴리오 파일 위치가 바뀌었습니다.</p>
      <p>
        <code>return /;</code>
      </p>
      <a class="portfolio-link-button" href="/">포트폴리오 홈으로 돌아가기</a>
    </section>
  </main>
</BaseLayout>
