---
import BaseLayout from "@/layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    { params: { notFound: "not-found" } },
    { params: { notFound: "404" } },
  ];
}
---

<BaseLayout
  title="프로젝트를 찾을 수 없습니다 | 김민준 Portfolio"
  description="요청한 프로젝트 경로를 찾을 수 없습니다. 포트폴리오 홈으로 돌아가 프로젝트 목록을 확인할 수 있습니다."
  canonical="https://minjoon.me/projects/not-found/"
>
  <main id="main" class="portfolio-not-found portfolio-reading">
    <section class="not-found-panel" aria-labelledby="not-found-title">
      <p class="code-comment">// 404</p>
      <h1 id="not-found-title">프로젝트 경로를 찾을 수 없습니다.</h1>
      <p>프로젝트 파일명이 바뀌었거나 아직 정리되지 않은 경로입니다.</p>
      <a class="portfolio-link-button" href="/">포트폴리오 홈으로 돌아가기</a>
    </section>
  </main>
</BaseLayout>
